      },
      "extensions": ["rust-lang.rust-analyzer", "golang.go", "llvm-vs-code-extensions.vscode-clangd", "vadimcn.vscode-lldb"],
      "notes": ["vision off frees VRAM/disk", "coder context raised for cross-crate/package reasoning (capped by what the hardware allows)"]
    },
