  "usecases": {
    "_comment": "Overlays applied on top of the hardware tier by `lai plan` (or the UI). Per role: enabled true/false and optional ctx override. Hardware still rules: an enabled role only activates if a model fits.",
    "general": {
      "label": "General / mixed development",
      "overlay": {},
      "extensions": [],
      "notes": ["tier defaults, nothing changed"]
    },
    "web": {
      "label": "Web & WordPress (PHP / JS / TS, themes, sites)",
      "overlay": {
        "vision": {"enabled": true},
        "thinker": {"enabled": false},
        "autocomplete": {"ctx": 16384}
      },
      "extensions": ["bmewburn.vscode-intelephense-client (PHP)", "dbaeumer.vscode-eslint", "bradlc.vscode-tailwindcss", "esbenp.prettier-vscode"],
      "notes": ["vision on: design screenshots -> markup is a daily move", "autocomplete gets more context for long template files"]
    },
    "mobile": {
      "label": "Mobile apps (Android / iOS / Flutter / React Native)",
      "overlay": {
        "vision": {"enabled": true, "ctx": 16384},
        "thinker": {"enabled": true}
      },
      "extensions": ["Kotlin / Swift language servers via the platform IDEs", "Dart-Code.flutter (Flutter)", "msjsdiag.vscode-react-native"],
      "notes": ["vision prioritized: UI mockups and screenshots are the main input", "heavy UI work is best in Android Studio/Xcode with this stack as the API backend"]
    },
