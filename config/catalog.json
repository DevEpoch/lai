  "engines": {
    "_comment": "asset regex patterns for the llama.cpp GitHub release, keyed by <platform>-<vendor-class>",
    "windows-cuda":   {"patterns": ["bin-win.*cuda.*x64.*\\.zip$"], "exclude": "cudart", "cudart": "cudart.*win.*x64.*\\.zip$", "note": "NVIDIA CUDA build"},
    "windows-vulkan": {"patterns": ["bin-win.*vulkan.*x64.*\\.zip$"], "note": "AMD/Intel GPUs on Windows run best on Vulkan"},
    "windows-cpu":    {"patterns": ["bin-win.*cpu.*x64.*\\.zip$", "bin-win.*x64.*\\.zip$"], "note": "CPU-only build"},
    "linux-cuda":     {"patterns": ["bin-ubuntu.*cuda.*x64.*\\.(zip|tar\\.gz)$", "bin-ubuntu.*x64.*\\.(zip|tar\\.gz)$"], "note": "if no CUDA asset is published, build from source with -DGGML_CUDA=ON"},
    "linux-vulkan":   {"patterns": ["bin-ubuntu.*vulkan.*\\.(zip|tar\\.gz)$", "bin-ubuntu.*x64.*\\.(zip|tar\\.gz)$"], "note": "Vulkan works everywhere; a ROCm source build is ~10-20% faster on supported Radeons"},
    "linux-cpu":      {"patterns": ["bin-ubuntu.*x64.*\\.(zip|tar\\.gz)$"], "note": "CPU-only"},
    "mac-metal":      {"patterns": ["bin-macos-arm64.*\\.zip$", "bin-macos.*\\.zip$"], "note": "Metal is built in; MLX (LM Studio / mlx-lm) is ~10-25% faster but has no llama-swap equivalent - llama.cpp keeps one API everywhere"},
    "llama_swap": {
      "windows": ["windows.*amd64.*\\.zip$"],
      "linux":   ["linux.*amd64.*\\.tar\\.gz$"],
      "mac":     ["darwin.*arm64.*\\.tar\\.gz$", "darwin.*amd64.*\\.tar\\.gz$"]
    }
  },

