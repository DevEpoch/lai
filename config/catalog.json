    "python-ml": {
      "label": "Python data science / ML project",
      "usecase": "data-ml",
      "toolchains": [{"bin": "python", "hint": "already present (lai runs on it)"}],
      "init_cmds": [],
      "files": {
        "pyproject.toml": "[project]\nname = \"{name}\"\nversion = \"0.1.0\"\nrequires-python = \">=3.10\"\ndependencies = []\n\n[tool.ruff]\nline-length = 100\n",
        "src/{name}/__init__.py": "",
        "src/{name}/main.py": "def main() -> None:\n    print(\"hello, world\")\n\n\nif __name__ == \"__main__\":\n    main()\n",
        "tests/test_smoke.py": "def test_smoke():\n    assert True\n"},
      "agents": {"build": "-", "test": "pytest", "lint": "ruff check .", "run": "python -m {name}.main"},
      "extensions": ["ms-python.python", "ms-toolsai.jupyter", "charliermarsh.ruff"],
      "gitignore": [".venv/", "__pycache__/", "*.egg-info/"],
      "required_roles": ["coder", "thinker", "vision", "embeddings"],
      "min_ctx": 16384
    }
