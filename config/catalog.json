  "stacks": {
    "_comment": "Project scaffolds for `lai new`. init_cmds use the ecosystem's own generator ({name} = sanitized project name, {python} = current interpreter); files are minimal seeds only where no generator exists. agents.* feed the generated AGENTS.md.",
    "go-cli": {
      "label": "Go command-line tool",
      "usecase": "systems",
      "toolchains": [{"bin": "go", "hint": "winget install GoLang.Go | brew install go | sudo apt install golang"}],
      "init_cmds": [["go", "mod", "init", "{name}"]],
      "files": {"main.go": "package main\n\nimport (\n\t\"flag\"\n\t\"fmt\"\n)\n\nfunc main() {\n\tname := flag.String(\"name\", \"world\", \"who to greet\")\n\tflag.Parse()\n\tfmt.Printf(\"hello, %s\\n\", *name)\n}\n"},
      "agents": {"build": "go build ./...", "test": "go test ./...", "lint": "go vet ./...", "run": "go run ."},
      "extensions": ["golang.go"],
      "gitignore": ["bin/"],
      "required_roles": ["coder", "thinker", "autocomplete", "embeddings"],
      "min_ctx": 32768
    },
